# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/sms-backend

# JWT Secret (change in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server Port
PORT=8000

# CORS Origin (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# External Permission API
PERMISSION_API_URL=http://localhost:3001/api/permissions

# Partner API Key
PARTNER_API_KEY=partner-secret-key
